# Copy to `.env` or `.env.local` for local dev and set the same keys in Cloudflare Pages → Settings → Environment variables.

# MongoDB (required for Admin + live portfolio data)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# Admin login (required for /admin and POST /api/upload)
ADMIN_USER=your_username
ADMIN_PASS=your_strong_password

# Contact form (optional — if unset, form uses mailto:)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
